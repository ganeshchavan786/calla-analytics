# ============================================================
# CallLog SaaS — Environment Variables
# Development: cp .env.example .env
# Production: Fill in all values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# Database (SQLite = dev, PostgreSQL = production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@host:5432/calllog_db"

# Auth — Min 32 chars random string
# Generate: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRY=7d

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=calllog-uploads

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Pusher Realtime (Optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=ap2
