// prisma/schema.prisma — COMPLETE FINAL SCHEMA

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // ✅ SQLite — Default (zero setup)
  provider = "sqlite"
  url      = "file:./dev.db"

  // 🚀 PostgreSQL — Production साठी uncomment करा
  // provider = "postgresql"
  // url      = env("DATABASE_URL")

  // 🚀 MySQL / PlanetScale
  // provider = "mysql"
  // url      = env("DATABASE_URL")
}

// =============================================================
// ORGANIZATION
// =============================================================

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  logoUrl             String?
  timezone            String    @default("UTC")
  status              String    @default("ACTIVE")      // ACTIVE, BLOCKED, SUSPENDED
  planType            String    @default("FREE_TRIAL")  // FREE_TRIAL, ACTIVE_PAID
  subscriptionEndDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  members        OrganizationMember[]
  callLogs       CallLog[]
  tags           Tag[]
  tasks          FollowUpTask[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  importBatches  ImportBatch[]
  invites        Invite[]
  reports        SavedReport[]
  registeredSIMs RegisteredSIM[]
}

// =============================================================
// USER
// =============================================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String
  avatarUrl        String?
  isVerified       Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?

  // Email Verification OTP
  verificationOtp  String?
  otpExpiry        DateTime?

  // Mobile App Code
  uniqueCode       String?   @unique  // OWN-4829 या EMP-7341
  codeType         String?            // "OWNER" | "EMPLOYEE"

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  memberships    OrganizationMember[]
  importedLogs   CallLog[]
  notes          CallNote[]
  assignedTasks  FollowUpTask[]       @relation("TaskAssignee")
  createdTasks   FollowUpTask[]       @relation("TaskCreator")
  watchedTasks   TaskWatcher[]
  comments       TaskComment[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  importBatches  ImportBatch[]
  registeredSIMs RegisteredSIM[]
}

// =============================================================
// REGISTERED SIM (NEW)
// =============================================================

model RegisteredSIM {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  simSlot        String    // "SIM_1" | "SIM_2"
  phoneNumber    String
  deviceName     String?
  deviceId       String    @default("unknown")
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  totalSynced    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId, simSlot])
  @@index([userId])
  @@index([organizationId])
  @@index([phoneNumber])
}

// =============================================================
// RBAC
// =============================================================

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("MEMBER") // OWNER | ADMIN | MEMBER | GUEST
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Invite {
  id             String    @id @default(cuid())
  email          String
  role           String    @default("MEMBER")
  token          String    @unique
  organizationId String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email])
}

// =============================================================
// CALL LOGS
// =============================================================

model CallLog {
  id             String    @id @default(cuid())
  organizationId String
  importedById   String
  importBatchId  String?
  mobileNumber   String
  contactName    String?
  callType       String    // INCOMING | OUTGOING | MISSED
  date           DateTime
  duration       Int       @default(0)
  simSlot        String    @default("UNKNOWN")
  deviceName     String?
  recordingLink  String?
  isImportant    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedBy   User          @relation(fields: [importedById], references: [id])
  importBatch  ImportBatch?  @relation(fields: [importBatchId], references: [id])
  notes        CallNote[]
  tags         CallLogTag[]
  tasks        FollowUpTask[]

  @@index([organizationId])
  @@index([mobileNumber])
  @@index([callType])
  @@index([date])
  @@index([organizationId, date])
  @@index([organizationId, mobileNumber])
  @@index([organizationId, callType])
  @@index([deletedAt])
}

model CallNote {
  id        String   @id @default(cuid())
  callLogId String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callLog CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([callLogId])
}

// =============================================================
// TAGS
// =============================================================

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  callLogs     CallLogTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model CallLogTag {
  callLogId String
  tagId     String
  addedAt   DateTime @default(now())

  callLog CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([callLogId, tagId])
  @@index([tagId])
}

// =============================================================
// IMPORT BATCHES
// =============================================================

model ImportBatch {
  id             String    @id @default(cuid())
  organizationId String
  importedById   String
  source         String    // CSV | EXCEL | ANDROID_BACKUP | MANUAL | API | MOBILE_SYNC
  status         String    @default("PENDING")
  fileName       String?
  fileSize       Int?
  totalRows      Int       @default(0)
  successRows    Int       @default(0)
  failedRows     Int       @default(0)
  errorLog       String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedBy   User         @relation(fields: [importedById], references: [id])
  callLogs     CallLog[]

  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
}

// =============================================================
// FOLLOW-UP TASKS
// =============================================================

model FollowUpTask {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  description    String?
  status         String    @default("PENDING")
  priority       String    @default("MEDIUM")
  dueDate        DateTime?
  assigneeId     String?
  linkedCallId   String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy    User            @relation("TaskCreator", fields: [createdById], references: [id])
  linkedCall   CallLog?        @relation(fields: [linkedCallId], references: [id])
  comments     TaskComment[]
  watchers     TaskWatcher[]
  attachments  TaskAttachment[]

  @@index([organizationId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   FollowUpTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User         @relation(fields: [authorId], references: [id])

  @@index([taskId])
}

model TaskWatcher {
  taskId  String
  userId  String
  addedAt DateTime @default(now())

  task FollowUpTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  fileName   String
  fileSize   Int
  mimeType   String
  url        String
  uploadedAt DateTime @default(now())

  task FollowUpTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// =============================================================
// NOTIFICATIONS
// =============================================================

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  body           String
  link           String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([organizationId])
  @@index([userId, createdAt])
}

// =============================================================
// AUDIT LOG
// =============================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  action         String
  entityType     String
  entityId       String
  metadata       String   // JSON stringified
  ipAddress      String?
  timestamp      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation(fields: [actorId], references: [id])

  @@index([organizationId])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

// =============================================================
// SAVED REPORTS
// =============================================================

model SavedReport {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String
  filters        String
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// =============================================================
// LICENSE MANAGER MODELS (Isolated — existing models touch नाही)
// =============================================================

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Super Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LicenseSettings {
  id             String   @id @default(cuid())

  // SMTP Config
  smtpHost       String   @default("")
  smtpPort       Int      @default(587)
  smtpUser       String   @default("")
  smtpPass       String   @default("")
  smtpSecure     Boolean  @default(false)
  fromEmail      String   @default("")
  fromName       String   @default("CallLog SaaS")

  // App Config
  appName        String   @default("CallLog SaaS")
  supportEmail   String   @default("")
  appUrl         String   @default("")

  // Cron Config
  cronReportEmail    String   @default("")
  cronReportTime     String   @default("09:00")
  cronReportEnabled  Boolean  @default(true)

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

